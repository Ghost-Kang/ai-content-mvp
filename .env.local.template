# Copy to .env.local and fill in values. Never commit .env.local.

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only, never expose to client

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/create
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/create

# LLM — International (required for INTL region)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# LLM — China (required for CN region, leave blank if not supporting CN)
ERNIE_API_KEY=[api-key]:[secret-key]   # format: apiKey:secretKey
QWEN_API_KEY=sk-...
KIMI_API_KEY=sk-...

# Vercel AI Gateway (optional — unified provider routing)
AI_GATEWAY_API_KEY=

# Video generation — Seedance via Volcengine Ark (D24 default for v3.0)
# Get a key at: https://www.volcengine.com/docs/82379/1541594
SEEDANCE_API_KEY=
# Optional overrides — defaults below match D24 assumptions
# SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com
# SEEDANCE_MODEL=doubao-seedance-1-0-pro-250528  # default; activated SKU on Ark 2026-04-26
# SEEDANCE_COST_PER_SEC_FEN=60   # ¥6/10s clip = 60 分/sec; W2-04 PoC will retune

# W2-05 — VideoGenNodeRunner toggles
# WORKFLOW_VIDEO_RESOLUTION=720p          # 480p / 720p / 1080p
# WORKFLOW_VIDEO_POLL_INTERVAL_MS=2000    # how often to poll Seedance per frame
# WORKFLOW_VIDEO_POLL_MAX_WAIT_MS=300000  # 5 min hard ceiling per frame
# WORKFLOW_VIDEO_MAX_FRAMES_PER_RUN=3     # demo cost guard; leave unset for full storyboard

# W3-04 — Export bundle (Supabase Storage)
# Bucket name is fixed to `workflow-exports` (see lib/storage/supabase.ts).
# Run `pnpm storage:probe` once after first DATABASE_URL setup to create the
# bucket + verify the service-role key has Storage write permission.
# WORKFLOW_EXPORT_SIGNED_URL_TTL_SEC=604800   # signed URL TTL (default 7 days)
# WORKFLOW_EXPORT_SKIP_BUNDLE=1               # local dev: skip zip+upload, leave output.bundle=null

# W4-01 — Spend caps (CNY). Leave blank to use defaults.
LLM_DAILY_CAP_CNY=50                   # global per UTC day; default 50
LLM_TENANT_DAILY_CAP_CNY=5             # per tenant per UTC day; default 5
# Per-1K-token cost in 分 (fen). Defaults provide safety margin.
# LLM_COST_PER_1K_FEN_KIMI=20
# LLM_COST_PER_1K_FEN_OPENAI=40
# LLM_COST_PER_1K_FEN_ANTHROPIC=150
# LLM_COST_PER_1K_FEN_QWEN=12
# LLM_COST_PER_1K_FEN_ERNIE=12

# Data source — 新榜数据开放平台 (D31, 2026-04-25 签约)
# 4 平台日更榜单：抖音 / 快手 / 小红书 / B站
# Rate limit: 200/min（W4-01 client 内置 token bucket）
# Used by `lib/data-source/newrank/` for W4-01..04 trending fetch.
# Apifox 文档（需密码访问，不存进 git）—— 见 .env.local 注释
NEWRANK_API_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# For CN deployment, override with self-hosted PostHog endpoint:
# NEXT_PUBLIC_POSTHOG_HOST=https://analytics.your-cn-domain.com

# Upstash (job queue)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
QSTASH_TOKEN=...
QSTASH_CURRENT_SIGNING_KEY=...
QSTASH_NEXT_SIGNING_KEY=...
# QStash region endpoint. Default `https://qstash.upstash.io` routes to
# the EU region — if your account lives in US (or anywhere else) you'll
# get: "user (...) not found in this region (...)". Set explicitly:
#   US East:    https://qstash-us-east-1.upstash.io
#   EU Central: https://qstash-eu-central-1.upstash.io
# Format is `qstash-<region>.upstash.io` (NOT `<region>.qstash.upstash.io` —
# the latter does not resolve). Find your region in Upstash Console.
# Docs: https://upstash.com/docs/qstash/howto/multi-region
# QSTASH_URL=https://qstash-us-east-1.upstash.io

# W2-07a — Workflow dispatcher
# Mode picker for `workflow.run` mutation:
#   inline  — run orchestrator in-process, fire-and-forget (DEV default)
#   qstash  — publish to QStash + worker route /api/workflow/run runs it (PROD)
# Leave unset to auto-detect: qstash if QSTASH_TOKEN + a public URL is
# available (VERCEL_URL / NEXT_PUBLIC_APP_URL / WORKFLOW_WORKER_BASE_URL),
# else inline. Recommended for local dev: don't set, rely on auto-detect.
# WORKFLOW_DISPATCH_MODE=inline
#
# Override the worker base URL (useful with ngrok/cloudflared for local
# QStash testing or non-Vercel deploys). No trailing slash.
# WORKFLOW_WORKER_BASE_URL=https://your-tunnel.ngrok.app
#
# DANGER: skip QStash signature verification on the worker route. Only
# for local debugging — never set this in production. The worker also
# auto-skips verification when the signing keys are missing entirely.
# WORKFLOW_WORKER_SKIP_SIGNATURE=1
